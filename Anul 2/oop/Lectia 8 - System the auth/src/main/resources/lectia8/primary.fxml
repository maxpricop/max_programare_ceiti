<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="10.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lectia8.controllers.PrimaryController">
   <children>
      <Label text="Autentificare" style="-fx-font-size:18px; -fx-font-weight:bold;" />
      <TextField fx:id="tfNume" promptText="Nume utilizator" />
      <TextField fx:id="tfEmail" promptText="Email (doar pentru înregistrare)" />
      <PasswordField fx:id="pfParola" promptText="Parolă" />
      <HBox spacing="10" alignment="CENTER">
         <children>
            <Button fx:id="btnAutentificare" text="Autentificare" onAction="#autentificare" />
            <Button fx:id="btnInregistrare" text="Înregistrare" onAction="#inregistrare" />
         </children>
      </HBox>
      <Label fx:id="lblMesaj" textFill="red" />
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
