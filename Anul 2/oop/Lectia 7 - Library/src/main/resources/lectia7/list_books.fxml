<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="8" xmlns:fx="http://javafx.com/fxml" fx:controller="lectia7.controllers.ListBooksController">
    <padding>
        <Insets top="12" right="12" bottom="12" left="12"/>
    </padding>

    <TableView fx:id="tableView" prefHeight="300.0" prefWidth="600.0">
        <columns>
            <TableColumn fx:id="titleColumn" text="Title" prefWidth="350.0"/>
            <TableColumn fx:id="authorColumn" text="Author" prefWidth="250.0"/>
        </columns>
    </TableView>

    <HBox spacing="8">
        <Button fx:id="addButton" text="Add" onAction="#handleAdd"/>
        <Button fx:id="findButton" text="Find" onAction="#handleFind"/>
        <Button fx:id="deleteButton" text="Delete selected" onAction="#handleDelete"/>
        <Button fx:id="saveButton" text="Save to file" onAction="#handleSave"/>
        <Button fx:id="refreshButton" text="Refresh" onAction="#handleRefresh"/>
    </HBox>

    <Label fx:id="messageLabel"/>
</VBox>
