<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="studiul_individual_1.controllers.SearchDialogController"
      stylesheets="@styles.css" styleClass="dialog-root"
      prefWidth="360">

   <VBox styleClass="dialog-content">
      <HBox spacing="10" alignment="CENTER_LEFT">
         <Label fx:id="promptLabel" />
         <TextField fx:id="inputField" HBox.hgrow="ALWAYS" />
      </HBox>
   </VBox>

   <HBox styleClass="dialog-button-bar">
      <Button text="Anulează" onAction="#onCancel" />
      <Button text="Caută" onAction="#onSearch" />
   </HBox>
</VBox>
